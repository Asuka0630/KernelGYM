# KernelGym Auto-Generated Configuration
# Generated on: Tue May 26 10:25:03 AM CST 2026

# Network
API_HOST=0.0.0.0
API_PORT=8101
API_WORKERS=4
API_RELOAD=false

# GPU
GPU_DEVICES=[0,1]
GPU_MEMORY_LIMIT=16GB
NODE_ID=amax9518

# Redis
REDIS_HOST=localhost
REDIS_PORT=8000
REDIS_DB=0
REDIS_PASSWORD=
REDIS_KEY_PREFIX=kernelgym

# Worker pool
WORKER_POOL_SIZE=1
MAX_TASKS_PER_WORKER=1

# Defaults
DEFAULT_TOOLKIT=kernelbench
DEFAULT_BACKEND_ADAPTER=kernelbench
DEFAULT_BACKEND=cuda
# Per-task wall-clock ceiling (compile + correctness + perf). Effective
# task budget on the worker = min(DEFAULT_TIMEOUT, payload.timeout).
DEFAULT_TIMEOUT=600

# Logging
LOG_LEVEL=INFO
LOG_DIR=logs

# Metrics
ENABLE_METRICS=true
METRICS_PORT=8002

# Profiling
ENABLE_PROFILING=true

# Errors
VERBOSE_ERROR_TRACEBACK=true

# Result persistence
SAVE_EVAL_RESULTS=false
EVAL_RESULTS_PATH=logs/eval_results.jsonl

# Compile offload
ENABLE_COMPILE_OFFLOAD=true
COMPILE_OFFLOAD_WORKERS=32
COMPILE_OFFLOAD_NVCC_THREADS=1
COMPILE_OFFLOAD_BUILD_ROOT=build
